---
import "../../styles/global.css";
import { getCollection, type CollectionEntry } from 'astro:content';

const name = "Connor Tunesi";

const posts = (await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft))
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
---

<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>Blog | {name}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@300;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-slate-50 text-slate-900 font-['Inter'] selection:bg-indigo-100 selection:text-indigo-700 min-h-screen flex flex-col">


<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200 px-8 py-5">
  <div class="max-w-6xl mx-auto flex justify-between items-center">
    <a href="/" class="font-extrabold tracking-tighter text-xl font-['Outfit'] uppercase hover:text-indigo-600 transition-colors">{name}</a>

    <div class="hidden md:flex items-center gap-8">
      <div class="flex gap-8 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400 border-r border-slate-200 pr-8">
        <a href="/#work" class="hover:text-indigo-600 transition-colors">Projects</a>
        <a href="/#experience" class="hover:text-indigo-600 transition-colors">Experience</a>
        <a href="/#tools" class="hover:text-indigo-600 transition-colors">Technical Stack</a>
        <a href="/blog" class="text-indigo-600">Blog</a>
      </div>
      <div class="flex gap-5 text-lg text-slate-400">
        <a href="https://github.com/iamDotNET" target="_blank" rel="noopener noreferrer" class="hover:text-slate-900 transition-colors" title="GitHub">
          <i class="bi bi-github"></i>
        </a>
        <a href="/connor-tunesi-resume.pdf" target="_blank" class="hover:text-slate-900 transition-colors" title="Download Resume">
          <i class="bi bi-file-earmark-arrow-down"></i>
        </a>
        <a href="https://www.linkedin.com/in/connor-tunesi-959326217/" target="_blank" rel="noopener noreferrer" class="hover:text-[#0077b5] transition-colors" title="LinkedIn Profile">
          <i class="bi bi-linkedin"></i>
        </a>
      </div>
      <a href="mailto:connortunesibusiness@gmail.com" class="bg-slate-900 text-white px-5 py-2 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-indigo-600 transition-all shadow-lg shadow-slate-200">Contact</a>
    </div>
  </div>
</nav>

<main class="max-w-6xl mx-auto px-8 w-full flex-1">

  <section class="py-16">
    <div class="flex items-center justify-between mb-10">
      <div class="flex items-center gap-3">
        <span class="h-px w-8 bg-indigo-600"></span>
        <h1 class="text-xs font-bold uppercase tracking-[0.3em] text-slate-400 font-['Outfit']">All Posts</h1>
      </div>
      <span class="text-xs text-slate-400 font-medium">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
    </div>

    {posts.length === 0 ? (
      <div class="bg-white border border-slate-200 rounded-3xl p-16 text-center shadow-sm">
        <i class="bi bi-journal-text text-4xl text-slate-300 block mb-4"></i>
        <p class="text-slate-400 text-sm font-medium">No posts yet — check back soon.</p>
      </div>
    ) : (
      <div class="space-y-6">
        {posts.map((post: CollectionEntry<'blog'>) => (
          <a
            href={`/blog/${post.slug}`}
            class="group flex flex-col md:flex-row md:items-center justify-between bg-white border border-slate-200 rounded-2xl p-8 md:p-10 shadow-sm hover:border-indigo-600 hover:shadow-md transition-all gap-6"
          >
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">
                  {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
                {post.data.tags && post.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="text-[10px] font-bold px-2 py-0.5 bg-indigo-50 text-indigo-600 border border-indigo-100 rounded-full uppercase tracking-wide">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-2xl font-bold tracking-tight font-['Outfit'] text-slate-950 mb-2 group-hover:text-indigo-600 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-slate-500 text-sm leading-relaxed font-light max-w-2xl">
                {post.data.description}
              </p>
            </div>
            <div class="shrink-0 flex items-center gap-2 text-sm font-bold text-indigo-600">
              Read Post
              <i class="bi bi-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

</main>

<footer class="py-16 bg-slate-950 text-white">
  <div class="max-w-6xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-8">
    <div>
      <a href="/" class="text-xl font-extrabold tracking-tighter font-['Outfit'] uppercase block mb-2 hover:text-indigo-400 transition-colors">{name}</a>
      <p class="text-xs text-slate-500 font-mono tracking-widest">
        Gameplay & Systems Engineer — Unreal Engine & Backend Infrastructure
      </p>
    </div>
    <div class="flex gap-10 text-[10px] font-bold uppercase tracking-[0.3em] text-slate-400">
      <a href="/#work" class="hover:text-white transition">Projects</a>
      <a href="/blog" class="hover:text-white transition text-indigo-400">Blog</a>
      <a href="mailto:connortunesibusiness@gmail.com" class="hover:text-white transition">Contact</a>
    </div>
  </div>
</footer>

</body>
</html>