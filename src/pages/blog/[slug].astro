---
import "../../styles/global.css";
import { getCollection, type CollectionEntry } from 'astro:content';

const name = "Connor Tunesi";

interface Props {
  post: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>{post.data.title} | {name}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@300;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-slate-50 text-slate-900 selection:bg-indigo-100 selection:text-indigo-700">

<!-- Reading progress bar -->
<div id="progress-bar" style="position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,#4f46e5,#3b82f6);z-index:100;width:0;transition:width 0.1s linear;"></div>

<!-- Nav -->
<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200 px-8 py-5">
  <div class="max-w-6xl mx-auto flex justify-between items-center">
    <a href="/" class="font-extrabold tracking-tighter text-xl font-['Outfit'] uppercase hover:text-indigo-600 transition-colors">{name}</a>
    <div class="hidden md:flex items-center gap-8">
      <div class="flex gap-8 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400 border-r border-slate-200 pr-8">
        <a href="/#work" class="hover:text-indigo-600 transition-colors">Projects</a>
        <a href="/#experience" class="hover:text-indigo-600 transition-colors">Experience</a>
        <a href="/#tools" class="hover:text-indigo-600 transition-colors">Technical Stack</a>
        <a href="/blog" class="text-indigo-600">Blog</a>
      </div>
      <div class="flex gap-5 text-lg text-slate-400">
        <a href="https://github.com/iamDotNET" target="_blank" rel="noopener noreferrer" class="hover:text-slate-900 transition-colors"><i class="bi bi-github"></i></a>
        <a href="/connor-tunesi-resume.pdf" target="_blank" class="hover:text-slate-900 transition-colors"><i class="bi bi-file-earmark-arrow-down"></i></a>
        <a href="https://www.linkedin.com/in/connor-tunesi-959326217/" target="_blank" rel="noopener noreferrer" class="hover:text-[#0077b5] transition-colors"><i class="bi bi-linkedin"></i></a>
      </div>
      <a href="mailto:connortunesibusiness@gmail.com" class="bg-slate-900 text-white px-5 py-2 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-indigo-600 transition-all shadow-lg shadow-slate-200">Contact</a>
    </div>
  </div>
</nav>

<main class="max-w-6xl mx-auto px-8">

  <!-- Post Header -->
  <header class="py-16 md:py-24 border-b border-slate-200">
    <a href="/blog" class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400 hover:text-indigo-600 transition-colors mb-8 group">
      <i class="bi bi-arrow-left group-hover:-translate-x-1 transition-transform"></i>
      All Posts
    </a>

    <div class="flex flex-wrap items-center gap-3 mb-5">
      {post.data.tags && post.data.tags.map((tag: string) => (
        <span class="text-[10px] font-bold px-2.5 py-1 bg-indigo-50 text-indigo-600 border border-indigo-100 rounded-full uppercase tracking-wide">{tag}</span>
      ))}
      <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">
        {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
      </span>
    </div>

    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-[1.08] text-slate-950 mb-5 font-['Outfit'] max-w-3xl">
      {post.data.title}
    </h1>
    <p class="text-lg text-slate-500 leading-relaxed font-light max-w-2xl">
      {post.data.description}
    </p>

    <div class="flex flex-wrap gap-6 mt-8 pt-8 border-t border-slate-100">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Author</p>
        <p class="text-sm font-semibold text-slate-700">{name}</p>
      </div>
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Published</p>
        <p class="text-sm font-semibold text-slate-700">{post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
      </div>
      {post.data.tags && (
        <div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Topics</p>
          <p class="text-sm font-semibold text-slate-700">{post.data.tags.join(', ')}</p>
        </div>
      )}
    </div>
  </header>

  <!-- Two-column: article + sidebar -->
  <div class="py-16 pb-24" style="display:grid;grid-template-columns:1fr;gap:3rem;align-items:start;">

    <!-- Article -->
    <div>
      <div class="bg-white border border-slate-200 rounded-3xl shadow-sm" style="padding:3.5rem;">
        <div id="post-content">
          <Content />
        </div>
      </div>
      <div class="mt-10">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm font-bold text-indigo-600 group">
          <i class="bi bi-arrow-left group-hover:-translate-x-1 transition-transform"></i>
          Back to all posts
        </a>
      </div>
    </div>

    <!-- Sidebar — shown via JS on lg screens -->
    <aside id="sidebar" style="display:none;position:sticky;top:6rem;">
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm" style="padding:1.5rem;">
        <div class="flex items-center gap-3 mb-5">
          <span style="height:1px;width:1.25rem;background:#4f46e5;display:block;"></span>
          <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-slate-400">On This Page</p>
        </div>
        <nav id="toc"></nav>
      </div>

      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm mt-4" style="padding:1.5rem;">
        <div class="flex items-center gap-3 mb-5">
          <span style="height:1px;width:1.25rem;background:#4f46e5;display:block;"></span>
          <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-slate-400">Details</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Author</p>
            <p class="text-xs font-semibold text-slate-700">{name}</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Date</p>
            <p class="text-xs font-semibold text-slate-700">{post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
          </div>
          {post.data.tags && (
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2">Tags</p>
              <div class="flex flex-wrap gap-1.5">
                {post.data.tags.map((tag: string) => (
                  <span class="text-[9px] font-bold px-2 py-0.5 bg-indigo-50 text-indigo-600 border border-indigo-100 rounded-full uppercase tracking-wide">{tag}</span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </aside>
  </div>
</main>

<footer class="py-16 bg-slate-950 text-white">
  <div class="max-w-6xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-8">
    <div>
      <a href="/" class="text-xl font-extrabold tracking-tighter font-['Outfit'] uppercase block mb-2 hover:text-indigo-400 transition-colors">{name}</a>
      <p class="text-xs text-slate-500 font-mono tracking-widest">Gameplay & Systems Engineer — Unreal Engine & Backend Infrastructure</p>
    </div>
    <div class="flex gap-10 text-[10px] font-bold uppercase tracking-[0.3em] text-slate-400">
      <a href="/#work" class="hover:text-white transition">Projects</a>
      <a href="/blog" class="hover:text-white transition text-indigo-400">Blog</a>
      <a href="mailto:connortunesibusiness@gmail.com" class="hover:text-white transition">Contact</a>
    </div>
  </div>
</footer>

<!-- 
  is:global bypasses Astro's scoped CSS and applies directly to 
  the rendered markdown HTML output inside #post-content 
-->
<style is:global>
  #post-content {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    color: #475569;
    line-height: 1.85;
  }

  #post-content h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #020617;
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #f1f5f9;
    scroll-margin-top: 6rem;
  }

  #post-content h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #0f172a;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    scroll-margin-top: 6rem;
  }

  #post-content h4 {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #64748b;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    scroll-margin-top: 6rem;
  }

  #post-content p {
    margin-top: 0;
    margin-bottom: 1.25rem;
    font-weight: 300;
    color: #475569;
    line-height: 1.85;
  }

  #post-content hr {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2.5rem 0;
  }

  #post-content ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem 0;
  }

  #post-content ul li {
    position: relative;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: #475569;
    font-weight: 300;
    line-height: 1.75;
  }

  #post-content ul li::before {
    content: "•";
    color: #4f46e5;
    font-weight: 700;
    position: absolute;
    left: 0;
  }

  #post-content ol {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem 0;
    counter-reset: item;
  }

  #post-content ol li {
    position: relative;
    padding: 0.25rem 0 0.25rem 1.75rem;
    color: #475569;
    font-weight: 300;
    line-height: 1.75;
    counter-increment: item;
  }

  #post-content ol li::before {
    content: counter(item) ".";
    color: #4f46e5;
    font-weight: 700;
    position: absolute;
    left: 0;
  }

  #post-content strong {
    font-weight: 600;
    color: #0f172a;
  }

  #post-content em {
    font-style: italic;
    color: #64748b;
  }

  #post-content a {
    color: #4f46e5;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  #post-content a:hover {
    color: #3730a3;
  }

  #post-content blockquote {
    background: #f8fafc;
    border-left: 3px solid #4f46e5;
    border-radius: 0 0.75rem 0.75rem 0;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    color: #64748b;
    font-style: italic;
  }

  #post-content blockquote p {
    margin-bottom: 0;
  }

  #post-content code:not(pre code) {
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    padding: 0.15em 0.45em;
    font-size: 0.83em;
    color: #4f46e5;
    font-family: 'Fira Code', monospace;
  }

  #post-content pre {
    background: #0f172a;
    border-radius: 0.875rem;
    border: 1px solid #1e293b;
    padding: 1.5rem 1.75rem;
    margin: 1.5rem 0 2rem;
    overflow-x: auto;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  }

  #post-content pre code {
    color: #e2e8f0;
    font-size: 0.83rem;
    font-family: 'Fira Code', monospace;
    line-height: 1.75;
    background: none;
    border: none;
    padding: 0;
  }

  #post-content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 1.5rem 0 2rem;
    border: 1px solid #e2e8f0;
  }

  #post-content th {
    text-align: left;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #64748b;
    padding: 0.75rem 1rem;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
  }

  #post-content td {
    padding: 0.65rem 1rem;
    color: #475569;
    border-bottom: 1px solid #f1f5f9;
  }

  #post-content tr:last-child td {
    border-bottom: none;
  }

  /* TOC sidebar links */
  .toc-link {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    color: #94a3b8;
    padding: 0.3rem 0 0.3rem 0.875rem;
    border-left: 2px solid #e2e8f0;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
    line-height: 1.4;
  }
  .toc-link:hover  { color: #4f46e5; border-color: #a5b4fc; }
  .toc-link.active { color: #4f46e5; border-color: #4f46e5; font-weight: 600; }
  .toc-link.toc-h3 { padding-left: 1.5rem; font-size: 0.7rem; }
</style>

<script>
  // Switch to two-column on large screens
  const layout = document.querySelector('.py-16.pb-24') as HTMLElement;
  const sidebar = document.getElementById('sidebar') as HTMLElement;
  function updateLayout() {
    if (window.innerWidth >= 1024) {
      layout.style.gridTemplateColumns = 'minmax(0,1fr) 260px';
      layout.style.gap = '4rem';
      sidebar.style.display = 'block';
    } else {
      layout.style.gridTemplateColumns = '1fr';
      sidebar.style.display = 'none';
    }
  }
  updateLayout();
  window.addEventListener('resize', updateLayout);

  // Reading progress
  const bar = document.getElementById('progress-bar') as HTMLElement;
  window.addEventListener('scroll', () => {
    const el = document.documentElement;
    bar.style.width = (el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100 + '%';
  });

  // Build TOC
  const article = document.getElementById('post-content');
  const tocEl   = document.getElementById('toc');
  if (article && tocEl) {
    const headings = Array.from(article.querySelectorAll('h2, h3'));
    if (headings.length === 0) {
      tocEl.innerHTML = '<p style="font-size:0.75rem;color:#94a3b8;font-style:italic;">No sections.</p>';
    } else {
      headings.forEach((h, i) => {
        if (!h.id) h.id = 'h-' + i;
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.className = 'toc-link' + (h.tagName === 'H3' ? ' toc-h3' : '');
        a.textContent = h.textContent || '';
        tocEl.appendChild(a);
      });

      const links = tocEl.querySelectorAll<HTMLAnchorElement>('.toc-link');
      const obs   = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            links.forEach(l => l.classList.remove('active'));
            tocEl.querySelector(`a[href="#${e.target.id}"]`)?.classList.add('active');
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px' });
      headings.forEach(h => obs.observe(h));
    }
  }
</script>

</body>
</html>